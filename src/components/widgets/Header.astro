---
import { Icon } from 'astro-icon/components';
import Logo from '~/components/Logo.astro';
import ToggleMenu from '~/components/common/ToggleMenu.astro';

import { getHomePermalink } from '~/utils/permalinks';
import { trimSlash } from '~/utils/permalinks';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface MenuLink extends Link {
  links?: Array<MenuLink>;
}

export interface Props {
  id?: string;
  links?: Array<MenuLink>;
  isSticky?: boolean;
  isDark?: boolean;
  isFullWidth?: boolean;
  position?: string;
}

const {
  id = 'header',
  links = [],
  isSticky = false,
  isDark = false,
  isFullWidth = false,
  position = 'center',
} = Astro.props;

const currentPath = `/${trimSlash(new URL(Astro.url).pathname)}`;
const brandGreen = '#0fbe7c';
---

<header
  class:list={[
    { sticky: isSticky, relative: !isSticky, dark: isDark },
    'top-0 z-40 flex-none mx-auto w-full border-b border-[#f1f1f1] transition-[opacity] ease-in-out bg-white text-black',
  ]}
  {...isSticky ? { 'data-aw-sticky-header': true } : {}}
  {...id ? { id } : {}}
>
  <div class="absolute inset-0"></div>
  <div class:list={[{ 'max-w-7xl': !isFullWidth }, 'relative text-black px-3 md:px-6 mx-auto w-full']}>
    <div class="flex items-center justify-start md:justify-center py-2 border-b border-[#f1f1f1] relative">
      <a class="flex items-center" href={getHomePermalink()} aria-label="SINDACATO ASEU">
        <Logo />
      </a>
      <div class="flex items-center md:hidden absolute right-0">
        <ToggleMenu />
      </div>
    </div>
    <nav
      class="items-center w-full uppercase tracking-normal font-semibold text-sm text-default hidden md:flex justify-center py-1"
      aria-label="Main navigation"
    >
      <ul
        class="flex flex-col md:flex-row md:self-center w-full md:w-auto text-sm md:justify-center [&>li]:mx-1"
      >
        {
          links.map(({ text, href, links }) => (
            <li class={links?.length ? 'dropdown' : ''}>
              {links?.length ? (
                <>
                  <div class="flex items-center">
                    {href ? (
                      <a
                        href={href}
                        class:list={[
                          'hover:text-[#0fbe7c] px-4 py-3 flex items-center whitespace-nowrap text-black',
                          { 'aw-link-active text-[#0fbe7c] font-semibold': href === currentPath },
                        ]}
                      >
                        {text}
                      </a>
                    ) : (
                      <span class="px-4 py-3 flex items-center whitespace-nowrap text-black">
                        {text}
                      </span>
                    )}
                    <button
                      type="button"
                      data-aw-toggle-submenu
                      class="hover:text-[#0fbe7c] px-2 py-3 flex items-center text-black md:px-1"
                      aria-label="Toggle submenu"
                    >
                      <Icon name="tabler:chevron-down" class="w-3.5 h-3.5 ml-0.5 rtl:ml-0 rtl:mr-0.5 md:hidden transition-transform duration-200" />
                      <Icon name="tabler:chevron-down" class="w-3.5 h-3.5 ml-0.5 rtl:ml-0 rtl:mr-0.5 hidden md:inline" />
                    </button>
                  </div>
                  <ul
                    class="dropdown-menu md:absolute md:hidden font-medium rounded border border-[#f1f1f1] bg-white text-black md:min-w-[260px] drop-shadow-xl pl-4 md:pl-0 max-h-0 md:max-h-none overflow-hidden md:overflow-visible transition-all duration-300"
                  >
                    {links.map(({ text: text2, href: href2 }) => (
                      <li>
                        <a
                          class:list={[
                            'first:rounded-t last:rounded-b hover:bg-gray-50 hover:text-[#0fbe7c] py-2 px-5 block whitespace-nowrap transition',
                            { 'aw-link-active': href2 === currentPath },
                          ]}
                          href={href2}
                        >
                          {text2}
                        </a>
                      </li>
                    ))}
                  </ul>
                </>
              ) : (
                <a
                  class:list={[
                    'hover:text-[#0fbe7c] px-4 py-3 flex items-center whitespace-nowrap',
                    { 'aw-link-active text-[#0fbe7c] font-semibold': href === currentPath },
                  ]}
                  href={href}
                >
                  {text}
                </a>
              )}
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

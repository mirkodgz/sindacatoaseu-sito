    id: 'modal-sede-milano-binda',
    title: 'Sede',
    zone: 'Sede',
    ref: 'Piscitelli Felice',
    phoneDisplay: '334.3716494',
    phoneLink: '3343716494',
    email: 'felicepiscitelli@hotmail.com',
    address: 'Via Binda, 33, Milano (MI) - 20143 Italia',
    summary: 'Via Binda, 33 — Milano (MI)',
    mapsUrl: 'https://maps.app.goo.gl/Gr73bJPFgGhgzETJ9',
    icon: '📍',
    lat: 45.4500,
    lng: 9.2000,
    city: 'Milano',
    province: 'MI',
  },

---

<PageLayout metadata={metadata}>
  <section class="relative w-full h-[50vh] md:h-[60vh] -mt-[76px] not-prose">
    <div class="absolute inset-0">
      <img
        src="/sedi-page-hero.jpg"
        alt="Sedi SINDACATO A.S.E.U."
        class="w-full h-full object-cover object-left md:object-center"
        loading="eager"
      />
    </div>
  </section>

  <section class="bg-white py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <p class="uppercase tracking-[0.2em] text-sm text-gray-500 mb-4">Sedi</p>
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">Rete territoriale SINDACATO A.S.E.U.</h1>
        <p class="text-base text-gray-700 max-w-3xl mx-auto mb-8">
          Assistenza sindacale, CAF e patronato in tutta Italia. Trova la sede più vicina a te.
        </p>
        <p class="text-base text-gray-600 max-w-2xl mx-auto mb-6">
          Seleziona una delle sedi per avere più informazioni.
        </p>
        <div class="flex justify-center mb-8">
          <img
            src="/GiftClick.gif"
            alt="Clicca per aprire i dettagli"
            class="h-16 w-auto"
            loading="lazy"
          />
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          sedi.map((sede) => (
            <article class="border border-gray-200 rounded-2xl p-6 shadow-sm hover:shadow-lg transition flex flex-col gap-4 bg-white">
              <div class="text-4xl">{sede.icon}</div>
              <div>
                <h3 class="text-xl font-semibold text-gray-900">{sede.title}</h3>
                <p class="text-base text-gray-500">{sede.summary}</p>
              </div>
              <button
                type="button"
                data-modal-target={sede.id}
                class="mt-auto inline-flex items-center justify-center px-4 py-2 rounded-full border border-[#0fbe7c] text-[#0fbe7c] font-semibold hover:bg-[#0fbe7c] hover:text-white transition"
              >
                Dettagli sede
              </button>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  {
    sedi.map((sede) => (
      <dialog id={sede.id} class="rounded-2xl border border-gray-200 p-0 w-full max-w-2xl">
        <div class="p-6 md:p-8 bg-white rounded-2xl">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="text-sm uppercase tracking-[0.2em] text-gray-500">{sede.zone}</p>
              <h3 class="text-2xl font-bold text-gray-900 mt-2">{sede.title}</h3>
            </div>
            <button
              type="button"
              class="text-gray-400 hover:text-gray-600"
              data-modal-close
              aria-label="Chiudi"
            >
              ✕
            </button>
          </div>

          <div class="mt-6 space-y-4 text-gray-700 text-base">
            {sede.ref && (
              <p>
                <span class="font-semibold text-gray-900">Referente:</span> {sede.ref}
              </p>
            )}
            {sede.phoneDisplay && (
              <p>
                <span class="font-semibold text-gray-900">Telefono:</span>{' '}
                {
                  sede.phoneLink ? (
                    <a href={`tel:${sede.phoneLink}`} class="text-[#0fbe7c] hover:underline">
                      {sede.phoneDisplay}
                    </a>
                  ) : (
                    sede.phoneDisplay
                  )
                }
              </p>
            )}
            {sede.email && (
              <p>
                <span class="font-semibold text-gray-900">Email:</span>{' '}
                <a href={`mailto:${sede.email}`} class="text-[#0fbe7c] hover:underline">
                  {sede.email}
                </a>
              </p>
            )}
            <p>
              <span class="font-semibold text-gray-900">Indirizzo:</span> {sede.address}
            </p>
            <p>
              <span class="font-semibold text-gray-900">Google Maps:</span>{' '}
              <a
                href={sede.mapsUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="text-[#0fbe7c] hover:underline"
              >
                Apri mappa
              </a>
            </p>
          </div>

          <div class="mt-8">
            <div class="text-sm font-semibold text-gray-700 mb-3">Anteprima mappa</div>
            <div class="rounded-2xl overflow-hidden border border-gray-100 shadow-inner">
              <iframe
                src={`https://www.google.com/maps?q=${encodeURIComponent(sede.address)}&output=embed`}
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                allowfullscreen
                class="w-full h-64 md:h-72"
              ></iframe>
            </div>
          </div>

          <div class="mt-8 flex flex-col sm:flex-row gap-3">
            <button
              type="button"
              data-modal-close
              class="inline-flex justify-center items-center px-5 py-2 rounded-full bg-gray-100 text-gray-800 font-semibold hover:bg-gray-200 transition"
            >
              Chiudi
            </button>
            <a
              href={sede.mapsUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex justify-center items-center px-5 py-2 rounded-full bg-[#0fbe7c] text-white font-semibold hover:bg-[#0ca868] transition"
            >
              Apri Google Maps
            </a>
          </div>
        </div>
      </dialog>
    ))
  }

  <style>
    dialog::backdrop {
      background: rgba(0, 0, 0, 0.55);
    }
  </style>

  <script>
    const initSediModals = () => {
      const openButtons = document.querySelectorAll('[data-modal-target]');
      const closeButtons = document.querySelectorAll('[data-modal-close]');

      openButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const targetId = button.getAttribute('data-modal-target');
          const dialog = document.getElementById(targetId);
          dialog?.showModal();
        });
      });

      closeButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const dialog = button.closest('dialog');
          dialog?.close();
        });
      });
    };

    if (typeof document !== 'undefined') {
      if (document.readyState !== 'loading') {
        initSediModals();
      } else {
        document.addEventListener('DOMContentLoaded', initSediModals);
      }
    }
  </script>
</PageLayout>


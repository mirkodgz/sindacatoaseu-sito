    email: 'ilcontabileonline@gmail.com',
    address: 'Via Monte Grappa, 8/D, Novara (NO) - 28100 Italia',
    summary: 'Via Monte Grappa, 8/D — Novara (NO)',
    mapsUrl: 'https://maps.app.goo.gl/Bsj5GqgyAZuCDaAb9',
    icon: '📍',
    lat: 45.4469,

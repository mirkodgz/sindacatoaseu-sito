---
import PageLayout from '~/layouts/PageLayout.astro';
import { getHomePermalink, getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'Pagina non trovata — SINDACATO ASEU',
  description: 'La pagina che stai cercando non è stata trovata.',
};
---

<PageLayout metadata={metadata}>
  <section class="flex items-center justify-center min-h-[70vh] py-16 bg-[#fbfbfb]">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center">
      <div class="mb-8">
        <div class="text-6xl mb-4">📍</div>
        <h1 class="text-6xl md:text-8xl font-bold text-[#0fbe7c] mb-6 font-heading">404</h1>
      </div>
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4 font-heading">Pagina non trovata</h2>
      <p class="text-base text-gray-600 mb-6 max-w-md mx-auto">
        La pagina che stai cercando non esiste o è stata spostata.
      </p>
      <p class="text-base text-gray-700 mb-8 max-w-md mx-auto font-semibold">
        SINDACATO ASEU è qui per aiutarti. Torna alla homepage o contattaci direttamente.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a
          href={getHomePermalink()}
          class="inline-flex items-center justify-center px-6 py-3 bg-[#0fbe7c] text-white font-semibold rounded-full hover:bg-[#0ca868] transition"
        >
          Torna alla homepage
        </a>
        <a
          href={getPermalink('/contatti')}
          class="inline-flex items-center justify-center px-6 py-3 border-2 border-[#0fbe7c] text-[#0fbe7c] font-semibold rounded-full hover:bg-[#0fbe7c] hover:text-white transition"
        >
          Contattaci
        </a>
      </div>
      <div class="mt-12 pt-8 border-t border-gray-200">
        <p class="text-sm text-gray-500 mb-2">Link utili:</p>
        <div class="flex flex-wrap justify-center gap-4 text-sm">
          <a href={getPermalink('/servizi')} class="text-[#0fbe7c] hover:underline">Servizi</a>
          <a href={getPermalink('/sedi')} class="text-[#0fbe7c] hover:underline">Sedi</a>
          <a href={getPermalink('/chi-siamo')} class="text-[#0fbe7c] hover:underline">Chi siamo</a>
          <a href={getPermalink('/dove-siamo')} class="text-[#0fbe7c] hover:underline">Dove siamo</a>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

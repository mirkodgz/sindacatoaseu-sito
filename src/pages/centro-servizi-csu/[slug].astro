---
import PageLayout from '~/layouts/PageLayout.astro';
import { getCollection } from 'astro:content';
import { getHomePermalink, getPermalink } from '~/utils/permalinks';

export async function getStaticPaths() {
  const csuServices = await getCollection('csu');
  return csuServices.map((service) => ({
    params: { slug: service.slug ?? service.data.slug },
    props: { service },
  }));
}

const { service: csuService } = Astro.props;

if (!csuService) {
  throw new Error('Centro Servizi CSU non trovato');
}

const { Content } = await csuService.render();
const metadata = {
  title: `${csuService.data.title} — Centro Servizi CSU | SINDACATO ASEU`,
  description: 'TODO: testo da inserire',
};
---

<PageLayout metadata={metadata}>
  <section class="mx-auto max-w-5xl px-6 py-16">
    <nav class="text-sm text-gray-500">
      <a class="hover:text-[#0fbe7c]" href={getHomePermalink()}>Home</a>
      <span class="mx-2">›</span>
      <a class="hover:text-[#0fbe7c]" href={getPermalink('/centro-servizi-csu')}>Centro Servizi CSU</a>
      <span class="mx-2">›</span>
      <span class="text-gray-900">{csuService.data.title}</span>
    </nav>

    <h1 class="mt-6 text-3xl font-bold uppercase text-gray-900">{csuService.data.title}</h1>

    {
      csuService.data.image && (
        <div class="mt-8">
          <img
            src={csuService.data.image}
            alt={csuService.data.title}
            class="w-full rounded-xl border border-gray-200 object-cover"
            loading="lazy"
          />
        </div>
      )
    }

    <article class="prose max-w-none mt-10">
      <Content />
    </article>
  </section>
</PageLayout>

---
import PageLayout from '~/layouts/PageLayout.astro';
import { getCollection } from 'astro:content';
import { getHomePermalink, getPermalink } from '~/utils/permalinks';

export async function getStaticPaths() {
  const services = await getCollection('servizi');
  return services.map((service) => ({
    params: { slug: service.slug ?? service.data.slug },
    props: { service },
  }));
}

const { service } = Astro.props;

if (!service) {
  throw new Error('Servizio non trovato');
}

const { Content } = await service.render();
const metadata = {
  title: `${service.data.title} — Servizi | SINDACATO A.S.E.U.`,
  description: 'TODO: testo da inserire',
};
---

<PageLayout metadata={metadata}>
  <section class="mx-auto max-w-5xl px-6 py-16">
    <nav class="text-sm text-gray-500">
      <a class="hover:text-[#0fbe7c]" href={getHomePermalink()}>Home</a>
      <span class="mx-2">›</span>
      <a class="hover:text-[#0fbe7c]" href={getPermalink('/servizi')}>Servizi</a>
      <span class="mx-2">›</span>
      <span class="text-gray-900">{service.data.title}</span>
    </nav>

    <h1 class="mt-6 text-3xl font-bold uppercase text-gray-900">{service.data.title}</h1>

    {service.data.image && (
      <div class="mt-8">
        <img
          src={service.data.image}
          alt={service.data.title}
          class="w-full rounded-xl border border-gray-200 object-cover"
          loading="lazy"
        />
      </div>
    )}

    <article class="prose max-w-none mt-10">
      <Content />
    </article>
  </section>
</PageLayout>


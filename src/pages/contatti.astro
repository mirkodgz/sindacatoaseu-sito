---
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';

const metadata = {
  title: 'Contatti — SINDACATO A.S.E.U.',
  description: 'Contatti sindacato ASEU Milano. Telefono, email, indirizzo sede. Contattaci per assistenza legale, fiscale e previdenziale. Consulenza gratuita.',
  keywords: 'contatti sindacato milano, telefono sindacato ASEU, email sindacato milano, indirizzo sindacato milano, sede sindacato ASEU milano, come contattare sindacato milano',
};
---

<Layout metadata={metadata}>
  <!-- Hero Section ******************* -->
  <section class="relative w-full h-[50vh] md:h-[60vh] -mt-[76px] not-prose">
    <div class="absolute inset-0">
      <img
        src="/contattaci-page-hero-def.webp"
        alt="Contatta il SINDACATO A.S.E.U."
        class="w-full h-full object-cover"
        loading="eager"
      />
    </div>
  </section>

  <!-- Contact Info ******************* -->
  <section class="bg-[#fbfbfb] py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Informazioni di contatto</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Card Indirizzo -->
        <div class="bg-white rounded-lg border border-gray-200 p-6 hover:border-[#0fbe7c] hover:shadow-lg transition-all flex flex-col">
          <div class="mb-4 flex justify-center">
            <Icon name="tabler:map-pin" class="w-16 h-16 text-[#0fbe7c]" />
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3 text-center">
            Indirizzo
          </h3>
          <div class="text-gray-600 text-base leading-relaxed mb-6 flex-grow text-center">
            <p class="font-semibold text-gray-900">SINDACATO A.S.E.U.</p>
            <p>Via Mario Pieri, 2</p>
            <p>Milano (MI) 20127</p>
          </div>
        </div>

        <!-- Card Telefono e Cellulare -->
        <div class="bg-white rounded-lg border border-gray-200 p-6 hover:border-[#0fbe7c] hover:shadow-lg transition-all flex flex-col">
          <div class="mb-4 flex justify-center">
            <Icon name="tabler:phone" class="w-16 h-16 text-[#0fbe7c]" />
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3 text-center">
            Contatti telefonici
          </h3>
          <div class="text-gray-600 text-base leading-relaxed mb-6 flex-grow text-center space-y-2">
            <div>
              <p class="text-sm text-gray-500 mb-1">Telefono</p>
              <a
                href="tel:022592773"
                class="text-[#0fbe7c] font-semibold hover:underline"
              >
                02.2592773
              </a>
            </div>
            <div>
              <p class="text-sm text-gray-500 mb-1">Cellulare</p>
              <a
                href="tel:3496250509"
                class="text-[#0fbe7c] font-semibold hover:underline"
              >
                349.6250509
              </a>
            </div>
          </div>
        </div>

        <!-- Card Email -->
        <div class="bg-white rounded-lg border border-gray-200 p-6 hover:border-[#0fbe7c] hover:shadow-lg transition-all flex flex-col">
          <div class="mb-4 flex justify-center">
            <Icon name="tabler:mail" class="w-16 h-16 text-[#0fbe7c]" />
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3 text-center">
            Email
          </h3>
          <div class="text-gray-600 text-base leading-relaxed mb-6 flex-grow text-center">
            <a
              href="mailto:info@sindacatoaseu.it"
              class="text-[#0fbe7c] font-semibold hover:underline break-all"
            >
              info@sindacatoaseu.it
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
